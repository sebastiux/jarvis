# Maytapi
MAYTAPI_PRODUCT_ID=tu_product_id
MAYTAPI_PHONE_ID=tu_phone_id
MAYTAPI_TOKEN=tu_token            # también acepta MAYTAPI_API_TOKEN

# Grok (xAI)
GROK_API_KEY=tu_grok_api_key      # también acepta XAI_API_KEY

# Base de datos (Railway la inyecta automáticamente al enlazar PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname   # también acepta POSTGRES_URL

# Tu número de WhatsApp con código de país (a quién le habla JARVIS)
MY_PHONE=521234567890
